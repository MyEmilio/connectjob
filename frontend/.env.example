# ===========================================
# ConnectJob Frontend - Environment Variables
# ===========================================
# IMPORTANT: Copy this file to .env and fill in your actual values
# NEVER commit .env file with real credentials to version control
# Set these in Vercel dashboard for production deployment

# ===========================================
# API Configuration
# ===========================================
# Backend API URL (production: your Railway app URL)
REACT_APP_API_URL=http://localhost:5000/api

# ===========================================
# Google OAuth (Optional)
# ===========================================
# Must match the Client ID in backend
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ===========================================
# Stripe (Optional)
# ===========================================
# Publishable key from: https://dashboard.stripe.com/apikeys
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
